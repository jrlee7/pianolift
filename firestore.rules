rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Personal single-family app: anyone holding the web config can
    // read/write the song library. Do not store anything sensitive here.
    match /songs/{songId} {
      allow read, write: if true;
    }
    match /folders/{folderId} {
      allow read, write: if true;
    }
    // History of converted source links so a video can be found again later.
    match /sources/{sourceId} {
      allow read, write: if true;
    }
  }
}
