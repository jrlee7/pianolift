{
  "name": "pianoforge",
  "private": true,
  "version": "0.1.0",
  "repository": "github:jrlee7/pianolift",
  "type": "module",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron-dev": "vite build && electron .",
    "electron-build": "vite build && electron-builder --publish never"
  },
  "dependencies": {
    "firebase": "^11.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-is-dev": "^3.0.1",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.pianoforge.app",
    "productName": "PianoForge",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.cjs",
      "../backend.exe"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
